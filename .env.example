# PyPong Environment Configuration
# Copy this file to .env and adjust values as needed

# Display Settings
WINDOW_WIDTH=1024
WINDOW_HEIGHT=720
FPS=60
FULLSCREEN=False

# Game Settings
WINNING_SCORE=5
DIFFICULTY=Medium

# Audio Settings
MUSIC_VOLUME=0.5
SFX_VOLUME=0.7
ENABLE_MUSIC=True

# Performance Settings
# Available profiles: low, medium, high, ultra
PERFORMANCE_PROFILE=medium
MAX_PARTICLES=50
MAX_TRAILS=20
ENABLE_EFFECTS=True
ENABLE_SCREEN_SHAKE=True

# Object Pooling Settings
BALL_POOL_SIZE=5
BALL_POOL_MAX=20
POWERUP_POOL_SIZE=10
POWERUP_POOL_MAX=30

# Debug Settings
DEBUG=False
LOG_LEVEL=INFO
SHOW_FPS=False
ENABLE_PROFILING=False

# Mobile Settings
TOUCH_CONTROLS=False
ADAPTIVE_RESOLUTION=True
BATTERY_SAVER=False

# Language
# Available: en, ru, es, de, fr, zh, ja
LANGUAGE=ru

# Accessibility
COLOR_BLIND_MODE=none
HIGH_CONTRAST=False
LARGE_UI=False
REDUCE_MOTION=False

