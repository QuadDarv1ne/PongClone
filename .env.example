# PyPong Environment Configuration
# Copy this file to .env and adjust values as needed

# Display Settings
WINDOW_WIDTH=1024
WINDOW_HEIGHT=720
FPS=60
FULLSCREEN=False

# Game Settings
WINNING_SCORE=5
DIFFICULTY=Medium

# Audio Settings
MUSIC_VOLUME=0.5
SFX_VOLUME=0.7
ENABLE_MUSIC=True

# Performance Settings
MAX_PARTICLES=50
MAX_TRAILS=20
ENABLE_EFFECTS=True

# Debug Settings
DEBUG=False
LOG_LEVEL=INFO
SHOW_FPS=False

# Mobile Settings
TOUCH_CONTROLS=False
ADAPTIVE_RESOLUTION=True

# Language
LANGUAGE=ru
